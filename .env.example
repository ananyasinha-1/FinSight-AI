# HUGGINGFACE_API_KEY: Required for Hugging Face Inference API calls.
# Get your API key from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY="hf_your_api_key_here"

# FIREBASE_SERVICE_ACCOUNT: Optional for local development.
# If omitted, the server falls back to Firebase REST APIs using the logged-in user's ID token.
# Set this to the full Firebase service account JSON for production/Admin SDK writes.
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
